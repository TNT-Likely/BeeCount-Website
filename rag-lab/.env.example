APP_ENV=dev
LOG_LEVEL=INFO

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=beecount_docs

# Corpus roots
DOCS_ZH_DIR=/workspace/docs
DOCS_EN_DIR=/workspace/i18n/en/docusaurus-plugin-content-docs/current

# Models
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-base
CLOUD_MODEL=glm-4-flash
OLLAMA_MODEL=qwen2.5:1.5b-instruct

# Providers
CLOUD_BASE_URL=
CLOUD_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Retrieval defaults
CHUNK_SIZE=450
CHUNK_OVERLAP=80
TOP_K_DENSE=20
TOP_K_BM25=20
HYBRID_ALPHA=0.6
MAX_CONTEXT_CHUNKS=6

# Runtime
DATA_DIR=./data
QUERY_CACHE_TTL_SECONDS=900
QUERY_CACHE_MAXSIZE=256
LOCAL_FALLBACK_ENABLED=true
HTTP_TIMEOUT_SECONDS=45

# OpenAI compatibility
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_DEFAULT_PROVIDER=local
OPENAI_COMPAT_FALLBACK_PROVIDER=cloud
OPENAI_COMPAT_ENABLE_STREAM=true
